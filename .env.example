# Required — GitHub Personal Access Token
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# Required — GitHub organization login (e.g. "octocat")
GITHUB_ORG=your-org-name

# Optional — how long (seconds) to cache API responses (default: 300)
CACHE_TTL_SECONDS=300

# Optional — max repos to fetch per refresh (default: 1000, sorted by most recently pushed)
# Large academic orgs can have 10 000+ repos; cap this to avoid hitting GitHub's rate limiter.
MAX_REPOS=1000
