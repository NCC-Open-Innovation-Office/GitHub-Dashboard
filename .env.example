# Required — GitHub Personal Access Token
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# Required — GitHub organization login (e.g. "octocat")
GITHUB_ORG=your-org-name

# Optional — default cache TTL for API responses (default: 300 seconds)
CACHE_TTL_SECONDS=300

# Optional — specific cache TTLs for different data types (in seconds)
# Org data changes infrequently, so longer cache is appropriate
ORG_CACHE_TTL_SECONDS=1800
# Repositories change more frequently
REPOS_CACHE_TTL_SECONDS=1200
# Contributors change moderately
CONTRIBUTORS_CACHE_TTL_SECONDS=900
# Activity feed should stay relatively fresh
ACTIVITY_CACHE_TTL_SECONDS=300
# Commit activity changes moderately
COMMIT_ACTIVITY_CACHE_TTL_SECONDS=600

# Optional — max repos to fetch per refresh (default: 1000, sorted by most recently pushed)
# Large academic orgs can have 10 000+ repos; cap this to avoid hitting GitHub's rate limiter.
MAX_REPOS=1000
